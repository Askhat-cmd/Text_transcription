bot_psychologist/tests/_tmp_memory_persistence/
bot_psychologist/tests/_tmp_memory_probe/
bot_psychologist/tests/test_sqlite.db*

telegram_adapter/telegram_sessions.db

# ========================================
# ЗАВИСИМОСТИ
# ========================================
node_modules/
.pnp
.pnp.js

# ========================================
