# ========================================
# Text Transcription - Monorepo .gitignore
# ========================================
# Общие правила для монорепозитория
# Специфичные правила для проектов находятся в их собственных .gitignore файлах

# ========================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ И КЛЮЧИ
# ========================================
.env
*.env
.env.local
.env.production
.env.*.local

# ========================================
# PYTHON
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Виртуальные окружения
.venv/
venv/
ENV/
env/
.venv.bak/
venv.bak/

# ========================================
# IDE И РЕДАКТОРЫ
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# ========================================
# ЛОГИ И ВРЕМЕННЫЕ ФАЙЛЫ
# ========================================
*.log
logs/
temp/
tmp/
.tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# ========================================
# ДАННЫЕ ПРОЕКТА (voice_bot_pipeline)
# ========================================
# Векторная база данных ChromaDB
voice_bot_pipeline/data/chromadb/

# Реестр видео (может содержать чувствительные данные)
voice_bot_pipeline/data/video_registry.json

# Логи пайплайна
voice_bot_pipeline/pipeline.log

# ========================================
# ДАННЫЕ ПРОЕКТА (bot_psychologist)
# ========================================
bot_psychologist/logs/
bot_psychologist/.cache_bot_agent/
bot_psychologist/data/
!bot_psychologist/data/.gitkeep
!bot_psychologist/data/threads/
