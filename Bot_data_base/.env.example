# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
PRIMARY_MODEL=gpt-4o-mini
REFINE_MODEL=gpt-5-mini
OPENAI_API_TIMEOUT=120.0
OPENAI_API_DELAY=2.0
OPENAI_API_MAX_RETRIES=3
OPENAI_API_RETRY_BACKOFF_BASE=2.0

# Sentence Transformers
SENTENCE_TRANSFORMERS_MODEL=intfloat/multilingual-e5-large
SENTENCE_TRANSFORMERS_DEVICE=

# API Server
API_HOST=0.0.0.0
API_PORT=8001

# YouTube Data API (optional)
YOUTUBE_API_KEY=

# Feature toggles
BOT_DB_DISABLE_EMBEDDINGS=0

# Pipeline paths
PIPELINE_SUBTITLES_DIR=data/uploads/subtitles
PIPELINE_BOOKS_UPLOADS_DIR=data/uploads/books
PIPELINE_YOUTUBE_OUTPUT_DIR=data/processed/youtube
PIPELINE_BOOKS_OUTPUT_DIR=data/processed/books

# Chunking
CHUNKING_BOOK_TARGET_TOKENS=1000
CHUNKING_BOOK_MIN_TOKENS=400
CHUNKING_BOOK_MAX_TOKENS=1400
CHUNKING_BOOK_OVERLAP_TOKENS=150
CHUNKING_YOUTUBE_MIN_TOKENS=200
CHUNKING_YOUTUBE_MAX_TOKENS=800

# SD labeling
SD_LABELING_ENABLED=true
SD_LABELING_MODEL=gpt-4o-mini
SD_LABELING_TEMPERATURE=0.1
SD_LABELING_MAX_TOKENS=300
SD_LABELING_MIN_CONFIDENCE=0.5
SD_LABELING_BATCH_SIZE=5

# Storage
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=bot_knowledge_base
JSON_EXPORT_DIR=data/processed
REGISTRY_PATH=data/registry.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
