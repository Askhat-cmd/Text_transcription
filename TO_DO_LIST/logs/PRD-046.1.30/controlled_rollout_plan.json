    "normal_user_provider_calls_allowed": false,
    "writer_prompt_change_allowed_for_normal_user": false,
    "writer_contract_change_allowed_for_normal_user": false,
    "final_answer_change_allowed_for_normal_user": false,
    "ready": true
  },
  "ready": true
}
