# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
HF_TOKEN="hf_xxxxxxxxxxxxxxxx"                        # Optional: Hugging Face token to avoid rate limits

# ===== LLM Configuration =====
# OpenAI model used by bot for answer generation.
# Environment variable is read in: bot_agent/config.py -> Config.LLM_MODEL
#
# Allowed values (Chat Completions API):
#   gpt-4o-mini        - fast, cheap, recommended for production (DEFAULT)
#   gpt-4o             - better quality, higher cost
#   gpt-4-turbo        - legacy, kept for compatibility
#   gpt-5-mini         - GPT-5 family: fast, cost-efficient (requires Tier 1+)
#   gpt-5              - GPT-5 family: flagship model (requires Tier 1+)
#
# IMPORTANT: GPT-5 family uses max_completion_tokens instead of max_tokens.
#            The bot selects this automatically based on model name.
PRIMARY_MODEL=gpt-4o-mini
# Model for fast routing classifiers. Defaults to gpt-4o-mini.
CLASSIFIER_MODEL=gpt-4o-mini
# Reasoning effort for reasoning models (gpt-5, o1/o3/o4): low/medium/high
REASONING_EFFORT=low

GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# ===== Conversation Memory =====
CONVERSATION_HISTORY_DEPTH=3       # How many recent turns to include in context
MAX_CONTEXT_SIZE=2000              # Max chars for conversation context
MAX_CONVERSATION_TURNS=1000        # Max stored turns per user

# ===== Semantic Memory =====
ENABLE_SEMANTIC_MEMORY=true
SEMANTIC_SEARCH_TOP_K=3
RETRIEVAL_TOP_K=5
MIN_RELEVANCE_SCORE=0.1
CONFIDENCE_CAP_HIGH=7
CONFIDENCE_CAP_MEDIUM=5
CONFIDENCE_CAP_LOW=3
CONFIDENCE_CAP_ZERO=0
SEMANTIC_MIN_SIMILARITY=0.7
SEMANTIC_MAX_CHARS=1000

# ===== Runtime Config (Admin UI hot-reload) =====
# Эти значения — дефолты. Изменения через /admin сохраняются в:
# bot_psychologist/data/admin_overrides.json

# ===== Voyage Rerank (optional) =====
VOYAGE_API_KEY=pa-...                             # Optional: Voyage API key
VOYAGE_MODEL=rerank-2
VOYAGE_TOP_K=5
VOYAGE_ENABLED=false                              # Enable Voyage rerank calls
RERANKER_ENABLED=false                            # New conditional gate (if true -> smart rerank mode)
RERANKER_CONFIDENCE_THRESHOLD=0.35
RERANKER_MODE_WHITELIST=THINKING,INTERVENTION
RERANKER_BLOCK_THRESHOLD=8

# ===== PRD Modernization Feature Flags =====
# Neo MindBot migration safety net (Phase 0)
NEO_MINDBOT_ENABLED=true
LEGACY_PIPELINE_ENABLED=false
USE_NEW_DIAGNOSTICS_V1=true
USE_DETERMINISTIC_ROUTE_RESOLVER=true
USE_PROMPT_STACK_V2=true
USE_OUTPUT_VALIDATION=true
INFORMATIONAL_BRANCH_ENABLED=true

# Existing modernization toggles
ENABLE_EMBEDDING_PROVIDER=true
ENABLE_CONDITIONAL_RERANKER=true
ENABLE_FAST_STATE_DETECTOR=true

# ===== Bot_data_base API =====
BOT_DB_URL=http://localhost:8003
BOT_DB_TIMEOUT=10.0
AUTHOR_BLEND_MODE=all   # all | single | blend
KNOWLEDGE_SOURCE=api    # "chromadb" = local file/Chroma loader, "api" = Bot_data_base HTTP

# Embedding Model Options:
# - intfloat/multilingual-e5-base (recommended default)
# - intfloat/multilingual-e5-large (GPU recommended)
# - paraphrase-multilingual-MiniLM-L12-v2 (legacy fallback)
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=auto

# ===== Conversation Summary =====
ENABLE_CONVERSATION_SUMMARY=true
SUMMARY_UPDATE_INTERVAL=5
SUMMARY_WINDOW_SIZE=5
RECENT_WINDOW=4
SUMMARY_MAX_CHARS=500

# ===== Session Storage (PRD v2.0 bootstrap) =====
ENABLE_SESSION_STORAGE=true
BOT_DB_PATH=data/bot_sessions.db
SESSION_RETENTION_DAYS=90
ARCHIVE_RETENTION_DAYS=365
AUTO_CLEANUP_ENABLED=true

# ===== Speed Layer (PRD v3.0.2) =====
WARMUP_ON_START=true        # Preload DataLoader, SemanticMemory, Retriever (and GraphClient if enabled) on startup
ENABLE_KNOWLEDGE_GRAPH=false # Knowledge Graph слой (рекомендуется false, если граф-данные не загружены)
ENABLE_STREAMING=true       # Enable /adaptive-stream SSE endpoint

# ===== LLM Payload Debug =====
LLM_PAYLOAD_INCLUDE_FULL_CONTENT=true
