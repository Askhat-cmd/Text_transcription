# Logs are local runtime artifacts. Attach logs to chat when needed.
logs/**
!logs/
!logs/.gitkeep
!logs/app/
!logs/app/.gitkeep
!logs/retrieval/
!logs/retrieval/.gitkeep
!logs/error/
!logs/error/.gitkeep

# Dependency directories
node_modules/

# Environment variables
.env

# Python caches / venv
__pycache__/
.pytest_cache/
.venv/
.cache_bot_agent/
.taskmaster/
*.db
*.db-journal

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS specific
.DS_Store

# Admin Config Panel runtime overrides
data/admin_overrides.json
config_override.json

# Prompt snapshots generated at startup
bot_agent/*.default.md
bot_agent/legacy/prompts/*.default.md
