    {
      "card_id": "program_imperfect_self_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Program Imperfect Self",
      "chunk_type": "concept",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The imperfect-self program is a stable inner pattern that reads ordinary experience through the feeling that something is wrong with me; explain it as a mechanism, not as a diagnosis or identity.",
      "mechanism_hints": ["imperfect_self", "shame", "self_fixing_loop"],
      "user_markers_examples": ["со мной что-то не так", "я недостаточно хорош", "несовершенное Я"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Explain softly as a learned mechanism. Do not label the user and do not offer a practice unless the user asks.",
      "safety_notes": ["not_a_diagnosis"],
      "writer_can_ignore": true
    },
    {
      "card_id": "five_survival_drivers_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Five Survival Drivers",
      "chunk_type": "concept",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The five survival drivers are learned inner rules that push a person toward safety, approval, or control; present them as patterns that can be noticed, not fixed by force.",
      "mechanism_hints": ["survival_drivers", "adaptive_rules", "approval_safety"],
      "user_markers_examples": ["пять драйверов", "драйверы выживания", "внутренние правила"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Give a compact overview and keep the tone human; avoid turning the answer into a rigid typology.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "be_strong_driver_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Be Strong Driver",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The Be Strong driver protects through endurance and emotional restraint; it often hides need, fear, or fatigue behind the demand to hold together.",
      "mechanism_hints": ["be_strong", "endurance", "emotional_restraint"],
      "user_markers_examples": ["будь сильным", "держаться через силу", "нельзя показывать слабость"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Name the protective function first. Do not shame the driver; show how it can be noticed gently.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "be_best_driver_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Be Best Driver",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The Be Best driver links safety and worth to flawless performance; it often turns growth into pressure and makes mistakes feel threatening.",
      "mechanism_hints": ["be_best", "perfection_pressure", "worth_performance"],
      "user_markers_examples": ["будь лучшим", "надо идеально", "ошибка недопустима"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Explain the pressure loop without encouraging more self-improvement pressure.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "please_others_driver_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Please Others Driver",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The Please Others driver seeks safety through approval and harmony; it can make personal boundaries feel risky.",
      "mechanism_hints": ["please_others", "approval_safety", "boundary_cost"],
      "user_markers_examples": ["радуй других", "надо понравиться", "страшно отказать"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Frame as a protective adaptation. Avoid blaming the user for adapting to relationships.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "try_harder_driver_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Try Harder Driver",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The Try Harder driver treats more effort as the answer even when rest, clarity, or a smaller step would help more.",
      "mechanism_hints": ["try_harder", "effort_loop", "self_pressure"],
      "user_markers_examples": ["старайся сильнее", "надо больше усилий", "я мало стараюсь"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Do not intensify the effort loop. Point to noticing the pressure before adding action.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "hurry_up_driver_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Hurry Up Driver",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "The Hurry Up driver creates a sense that safety depends on speed; it compresses attention and can make reflection feel dangerous.",
      "mechanism_hints": ["hurry_up", "urgency_loop", "compressed_attention"],
      "user_markers_examples": ["спеши", "быстрее", "я постоянно тороплюсь"],
