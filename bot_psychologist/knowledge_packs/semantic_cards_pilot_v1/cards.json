    {
      "card_id": "control_as_safety_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Control as Safety",
      "chunk_type": "mechanism",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "Control can function as a safety strategy: the system tries to reduce uncertainty by managing people, events, or inner states.",
      "mechanism_hints": ["control_as_safety", "uncertainty_reduction", "threat_prediction"],
      "user_markers_examples": ["контроль как безопасность", "мне нужно все контролировать", "без контроля тревожно"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
