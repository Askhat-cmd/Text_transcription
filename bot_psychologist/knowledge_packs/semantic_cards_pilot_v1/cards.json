      "writer_can_ignore": true
    },
    {
      "card_id": "fact_vs_interpretation_v1",
      "schema_version": "semantic_chunk_card_v1",
      "title": "Fact versus Interpretation",
      "chunk_type": "diagnostic_lens",
      "source_ref": {"source_doc": "Kuznica Duha v2", "section": "pilot curated card"},
      "core_thesis": "Separating fact from interpretation helps a person see what actually happened before the nervous system turns it into a story about danger, shame, or rejection.",
      "mechanism_hints": ["fact_interpretation", "meaning_making", "threat_story"],
      "user_markers_examples": ["это факт или интерпретация", "я додумал", "какие есть доказательства"],
      "allowed_use": ["direct_to_writer", "internal_lens"],
      "avoid_when": ["acute_crisis", "user_asked_no_theory"],
      "depth_level": 1,
      "quote_policy": "paraphrase_only",
      "practice_policy": "no_practice_unless_requested",
      "writer_instruction": "Use this as a gentle lens, not as a cross-examination.",
      "safety_notes": [],
      "writer_can_ignore": true
    },
    {
      "card_id": "panic_control_support_v1",
      "schema_version": "semantic_chunk_card_v1",
