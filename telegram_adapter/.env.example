# Copy this file to .env and fill values.

# Telegram token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=

# Neo MindBot API
NEO_API_URL=http://localhost:8000
NEO_API_KEY=dev-key-00...

# SQLite session cache path
SESSION_DB_PATH=./telegram_sessions.db

# Streaming timeout in seconds
STREAM_TIMEOUT_S=60.0

